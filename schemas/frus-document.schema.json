{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therealjameswilson.github.io/critical-minerals-records-stage-v2/schemas/frus-document.schema.json",
  "title": "History Stack FRUS document",
  "type": "object",
  "required": ["id", "series", "volume", "document_number", "stable_url", "volume_year_start", "volume_year_end", "metadata_status", "source_ids"],
  "properties": {
    "id": {"type": "string", "pattern": "^frus-[a-z0-9-]+$"},
    "series": {"const": "Foreign Relations of the United States"},
    "volume": {"type": "string"},
    "document_number": {"type": "string"},
    "title": {"type": ["string", "null"]},
    "date": {"type": ["string", "null"]},
    "participants": {"type": "array"},
    "country_ids": {"type": "array", "items": {"type": "string"}},
    "mineral_ids": {"type": "array", "items": {"type": "string"}},
    "policy_themes": {"type": "array", "items": {"type": "string"}},
    "source_note": {"type": ["string", "null"]},
    "stable_url": {"type": "string", "format": "uri"},
    "volume_context": {"type": "string"},
    "volume_year_start": {"type": "integer", "minimum": 1861, "maximum": 1992},
    "volume_year_end": {"type": "integer", "minimum": 1861, "maximum": 1992},
    "contextual_summary": {"type": ["string", "null"]},
    "statistic_ids": {"type": "array"},
    "agreement_ids": {"type": "array"},
    "law_ids": {"type": "array"},
    "nara_query_ids": {"type": "array"},
    "outcome": {"type": ["object", "null"]},
    "metadata_status": {"enum": ["verified-document", "subject-index-lead"]},
    "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
